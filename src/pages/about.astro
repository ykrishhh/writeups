---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About" description="About Writeups.">
  <section class="section container" style="max-width:760px;margin:0 auto;">
    <div class="reveal">
      <p class="kicker" style="font-size:11px;letter-spacing:0.22em;text-transform:uppercase;color:var(--accent-from);margin:0 0 14px;">About</p>
      <h1 style="font-family:var(--font-display);font-style:italic;font-weight:400;font-size:clamp(36px,7vw,64px);line-height:1.02;margin:0 0 20px;">Writeups</h1>
      <p class="lead" style="color:var(--muted);font-size:19px;">A collection of practical tutorials and reusable methods. Built with Astro, designed with the MotionSites system, deployed on GitHub Pages at <code>writeups.harrydev.one</code>.</p>
      <p>New writeups cover tooling, automation, and the small techniques that come up while building. Posts are meant to be read and reused, not just referenced.</p>
    </div>
  </section>
</BaseLayout>
